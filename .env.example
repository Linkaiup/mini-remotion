# 复制为 .env 并填入真实值: cp .env.example .env

# --- LLM (Harness Agent) ---
# stub | deepseek | openai
# 不填则: 有 DEEPSEEK_API_KEY 用 deepseek, 否则有 OPENAI_API_KEY 用 openai, 否则 stub
MINI_REMOTION_PROVIDER=deepseek

DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选: 仍可使用 OpenAI 兼容 API
# MINI_REMOTION_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- 引擎 ---
# MINI_REMOTION_DEV_URL=http://localhost:5173
# MINI_REMOTION_RENDER_MODE=bundle   # dev(默认) | bundle — CI 用预构建站点
# MINI_REMOTION_BUNDLE_URL=http://localhost:4173

# --- P3: 分布式队列 / Vision 质检 ---
# MINI_REMOTION_DISTRIBUTED_QUEUE=1  # 帧任务写入 out/queue/, 可多 worker 消费
# MINI_REMOTION_VISION_QA=1          # 抽帧 + 多模态 LLM 语义点评
# VISION_MODEL=gpt-4o-mini

# --- TTS ---
# noop 跳过 macOS say 旁白合成
# MINI_REMOTION_TTS=noop

# --- 图像生成 (火山方舟 Seedream 5.0) ---
ARK_API_KEY=your-ark-api-key-here
SEEDREAM_MODEL=doubao-seedream-5-0-260128
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDREAM_SIZE=2K
# SEEDREAM_WATERMARK=false
# MINI_REMOTION_IMAGES=noop   # 跳过图像生成

# --- 成本与调度 (P1) ---
# MAX_BUDGET_USD=0.5
# SEEDREAM_COST_USD=0.04
# LLM_PRICE_INPUT_PER_1M=0.27
# LLM_PRICE_OUTPUT_PER_1M=1.1
# MAX_POOL_SIZE=4
# RENDER_TIMEOUT_BASE_MS=30000
# RENDER_TIMEOUT_PER_FRAME_MS=500
# LLM_TIMEOUT_MS=120000
